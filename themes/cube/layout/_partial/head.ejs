<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <meta name="author" content="<%= config.author %>">
    <% if (config.description) { %>
    <meta name="description" content="<%= config.description %>">
    <% } %>
    <% let title = [config.title] %>
    <% if (page.tag) {
        title.unshift(`${__('tags')}: ${page.tag}`)
    } %>
    <% if (page.category) {
        title.unshift(`${__('categories')}: ${page.category}`)
    }%>
    <% if (page.archive) {
        title.unshift(`${__('archive_a')}`)
    }%>
    <% if (page.title) {
        title.unshift(`${page.title}`)
    }%>
    <title><%= title.join(' | ') %></title>
    <!-- inject:style -->
    <link href="<%- url_for('css/style.css') %>" rel="stylesheet" type="text/css">
    <!-- endinject -->
    <style>
        .cube-loading {
            top: 0;
            position: fixed;
            width: 100%;
            height: 100%;
            background: url('<%- url_for('images/lg/loading.gif') %>') no-repeat center center;
            background-color: rgba(0,0,0,.7);
        }

        .cube-loading.out {
            display: none;
        }

        .cube-loading:before {
            display: block;
            content: '<%= __('loading') %>';
            position: relative;
            width: 100%;
            top: 50%;
            right: -50%;
            color: #fff;
        }

        @media(max-width: 768px) {
            .cube-loading:before {
                font-size: 1.2em;
                transform: translate(-24px,20px);
                -webkit-transform: translate(-24px,20px);
                -o-transform: translate(-24px,20px);
                -ms-transform: translate(-24px,20px);
            }
        }

        @media(min-width: 768px) {
            .cube-loading:before {

            }
        }

        <% if (theme.opening_animation !== false) {
            let openingBackground = theme.background || (theme.header && theme.header.background)
            let openingIsUrl = /^(https?:)?\/\//.test(openingBackground || '')
            let openingUrl = openingBackground ? (openingIsUrl || openingBackground.charAt(0) === '/' ? openingBackground : url_for(`images/${openingBackground}`)) : ''
        %>
        .site-opening {
            position: fixed;
            inset: 0;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            pointer-events: none;
            background-color: #111;
            transform: translateY(0);
            animation: site-opening-exit 1s cubic-bezier(.76, 0, .24, 1) 1.45s forwards;
            will-change: transform;
        }

        .site-opening::before {
            content: '';
            position: absolute;
            inset: -2%;
            background-image: linear-gradient(rgba(0, 0, 0, .28), rgba(0, 0, 0, .38))<% if (openingUrl) { %>, url('<%- openingUrl %>')<% } %>;
            background-position: center;
            background-size: cover;
            transform: scale(1.08);
            animation: site-opening-zoom 2.1s ease forwards;
        }

        .site-opening::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            bottom: -22px;
            height: 44px;
            background: linear-gradient(to bottom, rgba(0, 0, 0, .32), rgba(0, 0, 0, 0));
        }

        .site-opening-title {
            position: relative;
            color: #fff;
            font-size: 36px;
            line-height: 1.25;
            text-align: center;
            text-shadow: 0 2px 14px rgba(0, 0, 0, .45);
            animation: site-opening-title 1.2s ease forwards;
        }

        @keyframes site-opening-zoom {
            from { transform: scale(1.12); }
            to { transform: scale(1); }
        }

        @keyframes site-opening-title {
            0% {
                opacity: 0;
                transform: translateY(18px);
            }
            35%, 75% {
                opacity: 1;
                transform: translateY(0);
            }
            100% {
                opacity: 0;
                transform: translateY(-12px);
            }
        }

        @keyframes site-opening-exit {
            from {
                transform: translateY(0);
            }
            to {
                transform: translateY(-110%);
                visibility: hidden;
            }
        }

        @media(max-width: 768px) {
            .site-opening-title {
                font-size: 26px;
                max-width: 86%;
            }
        }

        @media(prefers-reduced-motion: reduce) {
            .site-opening {
                display: none;
            }
        }
        <% } %>
    </style>
    <% if (theme.analytics.baidu) { %>
    <%- partial('analytics/baidu') %>
    <% } else if (theme.analytics.google) { %>
    <%- partial('analytics/google') %>
    <% } %>
</head>
